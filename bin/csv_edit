#!/usr/bin/env python3

# This script allows simple modification of csv files

import sys
import argparse
import os


def read_csv_records(stream):
  """Read complete CSV records from stream, handling multiline quoted fields."""
  current_lines = []
  in_quotes = False

  for raw_line in stream:
    line = raw_line.rstrip('\n')
    current_lines.append(line)

    for ch in line:
      if ch == '"':
        in_quotes = not in_quotes

    if not in_quotes:
      yield '\n'.join(current_lines)
      current_lines = []

  if current_lines:
    yield '\n'.join(current_lines)


def parse_csv_record(record):
  """Parse a CSV record into list of (value, was_quoted) tuples.
  Preserves quoting info so NULL vs empty string survives round-tripping."""
  fields = []
  i = 0
  n = len(record)

  while True:
    if i >= n:
      break

    if record[i] == '"':
      i += 1
      value_parts = []
      while i < n:
        if record[i] == '"':
          if i + 1 < n and record[i + 1] == '"':
            value_parts.append('"')
            i += 2
          else:
            i += 1
            break
        else:
          value_parts.append(record[i])
          i += 1
      fields.append((''.join(value_parts), True))
    else:
      value_parts = []
      while i < n and record[i] != ',':
        value_parts.append(record[i])
        i += 1
      fields.append((''.join(value_parts), False))

    if i < n and record[i] == ',':
      i += 1
      if i >= n:
        fields.append(('', False))

  return fields


def format_field(value, was_quoted):
  if was_quoted or ',' in value or '\n' in value or '"' in value:
    return '"' + value.replace('"', '""') + '"'
  return value


def format_record(fields):
  return ','.join(format_field(v, q) for v, q in fields)


def main():

  parser = argparse.ArgumentParser()
  parser.add_argument("-a","--add", help="Adds a new column with default value.", nargs=2, action='append')
  # parser.add_argument("-q","--query", help="Only prints selected column values.", nargs=2, action='append') # Not implemented yet.
  parser.add_argument("-d","--delete", help="Deletes a column.", action='append')
  parser.add_argument("-u","--update", help="Column name to update.", type=str)
  parser.add_argument("-n","--new-value", help="New value for update mode (required with -u).", type=str)
  parser.add_argument("-p","--print", help="Print input headers to stderr.", action="store_true")

  add_args = []
  delete_column_names = []
  args = vars(parser.parse_args())
  if args["add"]:
    add_args.extend(args["add"])
  if args["delete"]:
    delete_column_names.extend(args["delete"])
  
  # Validate update mode
  if args["update"] and not args["new_value"]:
    parser.error("-n/--new-value is required when -u/--update is specified")
  if args["new_value"] and not args["update"]:
    parser.error("-u/--update must be specified when using -n/--new-value")

  first = True
  headers = []
  delete_indicies = []
  update_column_index = None

  for record in read_csv_records(sys.stdin):
    fields = parse_csv_record(record)

    if first:
      first = False
      headers = [f[0] for f in fields]
      output_fields = list(fields)

      # Handle delete columns
      if delete_column_names:
        for delete_column_name in delete_column_names:
          match = False
          for i in range(0, len(headers)):
            if headers[i] == delete_column_name:
              delete_indicies.append(i)
              match = True
          if not match:
            raise Exception(f"No header for delete column: {delete_column_name}" + os.linesep)
        delete_indicies.sort(reverse=True)
        for di in delete_indicies:
          output_fields = output_fields[:di] + output_fields[di + 1:]

      # Handle add columns
      headers_set = set(headers)
      new_headers_set = set()
      for add_arg in add_args:
        new_column_name = add_arg[0]
        if new_column_name in headers_set or new_column_name in new_headers_set:
          raise Exception(f"Duplicate header name already exists: {new_column_name}" + os.linesep)
        output_fields.append((new_column_name, False))
        new_headers_set.add(new_column_name)

      if args["print"]:
        sys.stderr.write(", ".join(headers) + os.linesep)

      # Find update column index if in update mode
      if args["update"]:
        for i, header in enumerate(headers):
          if header == args["update"]:
            update_column_index = i
            break
        if update_column_index is None:
          raise Exception(f"No header for update column: {args['update']}" + os.linesep)

      print(format_record(output_fields))

    elif add_args or delete_column_names:
      output_fields = list(fields)
      for di in delete_indicies:
        output_fields = output_fields[:di] + output_fields[di + 1:]
      for add_arg in add_args:
        output_fields.append((add_arg[1], False))
      print(format_record(output_fields))

    elif args["update"]:
      fields[update_column_index] = (args["new_value"], fields[update_column_index][1])
      print(format_record(fields))

    else:
      print(record)

main()
